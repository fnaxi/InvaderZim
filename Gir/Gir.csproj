<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <ApplicationIcon>..\Images\Logo.ico</ApplicationIcon>
        <AssemblyName>Gir</AssemblyName>
        <RootNamespace>Gir</RootNamespace>
        <PackageId>Gir</PackageId>
        <Authors>Gir</Authors>
        <Company>Gir</Company>
        <Product>Gir</Product>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="DSharpPlus" Version="4.5.2" />
      <PackageReference Include="DSharpPlus.CommandsNext" Version="4.5.2" />
      <PackageReference Include="DSharpPlus.Interactivity" Version="4.5.2" />
      <PackageReference Include="DSharpPlus.SlashCommands" Version="4.5.2" />
      <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    </ItemGroup>

    <ItemGroup>
      <None Include="..\Images\Logo.ico">
        <Link>Logo.ico</Link>
      </None>
    </ItemGroup>

</Project>
